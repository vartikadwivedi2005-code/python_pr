   "source": [
    "def even_Fact(n):\n",
    "    ans = 1\n",
    "    for i in range(2,n+1,2):\n",
    "        ans *= i\n",
    "    return ans\n",
    "\n",
    "def odd_Fact(n):\n",
    "    ans = 1\n",
    "    for i in range(1,n+1,2):\n",
    "        ans *= i\n",
    "    return ans\n",
    "\n",
    "n = int(input(\"Enter the number:\"))\n",
    "if(n%2 == 0):\n",
    "    print(odd_Fact(n))\n",
    "else:\n",
    "    print(even_Fact(n))\n"
   ]
  }
